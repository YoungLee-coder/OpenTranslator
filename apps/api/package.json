{
  "name": "@opentranslator/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute opentranslator --local --file=src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute opentranslator --remote --file=src/db/schema.sql"
  },
  "dependencies": {
    "@opentranslator/shared-types": "workspace:*",
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
